{
  "name": "@urule/spec",
  "version": "0.1.0",
  "description": "Core entity types, package manifest schema, and validators for Urule",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "keywords": [
    "officeos",
    "ai",
    "manifest",
    "schema",
    "validation"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
