{
  "name": "github-connector",
  "version": "1.0.0",
  "type": "mcp_connector",
  "description": "MCP connector for GitHub — issues, PRs, repos, and actions",
  "author": "urule",
  "license": "MIT",
  "keywords": ["github", "mcp", "connector", "git"],
  "permissions": [
    { "resource": "secret:github-token", "level": "required" },
    { "resource": "network:api.github.com", "level": "required" }
  ],
  "compatibility": {
    "uruleVersion": ">=0.1.0"
  },
  "mcpConnector": {
    "serverCommand": "npx",
    "serverArgs": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "${secret:github-token}"
    },
    "tools": [
      "create_or_update_file",
      "search_repositories",
      "create_repository",
      "get_file_contents",
      "push_files",
      "create_issue",
      "create_pull_request",
      "list_issues",
      "list_commits"
    ],
    "authType": "api_key"
  }
}
