{
  "name": "urule",
  "version": "0.1.0",
  "private": true,
  "description": "Urule — The open-source coordination layer for AI agents.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "services/*",
    "plugins/*",
    "apps/*"
  ],
  "scripts": {
    "build:all": "npm run build --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "typecheck:all": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai-agents",
    "ai-platform",
    "control-plane",
    "mcp",
    "model-context-protocol",
    "orchestration",
    "langgraph",
    "anthropic",
    "claude",
    "fastify",
    "typescript",
    "approval-workflow",
    "human-in-the-loop",
    "widget-sdk",
    "multi-agent",
    "nats",
    "openfga",
    "open-source"
  ],
  "homepage": "https://urule.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/urule-os/urule.git"
  },
  "bugs": {
    "url": "https://github.com/urule-os/urule/issues"
  }
}
