{
  "name": "@urule/packagehub",
  "version": "0.1.0",
  "description": "Package metadata, search, and discovery service for Urule packages",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@urule/auth-middleware": "file:../urule-auth-middleware",
    "drizzle-orm": "^0.33.0",
    "fastify": "^5.0.0",
    "nats": "^2.28.0",
    "postgres": "^3.4.0",
    "ulid": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
